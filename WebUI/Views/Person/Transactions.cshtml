@model IEnumerable<Application.ViewModels.TransactionViewModel>

@{
    ViewData["Title"] = "Transactions";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class=" py-0">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-0">Transactions Management</h2>
            <p class="text-muted mb-0">Manage transactions and related accounts</p>
        </div>
    </div>

<!-- Active transaction styles moved to wwwroot/css/site.css -->
    <div class="row g-4">

        <!-- LEFT SIDE -->
        <div class="col-lg-4">

            <div class="card shadow-sm sidebar-card p-3" style="max-height: calc(100vh - 180px); overflow-y: auto;">

                <!-- Search -->
                <div class="mb-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search" aria-hidden="true"></i>
                        </span>
                        <input type="text" class="form-control border-start-0" placeholder="Search transactions...">
                    </div>
                </div>

                <!-- Transactions list -->
                @{ var transactions = Model ?? new List<Application.ViewModels.TransactionViewModel>(); var first = transactions.FirstOrDefault(); }
                @foreach(var transaction in transactions)
                {
                    var isDebit = transaction.Amount < 0;
                    <a href="#" data-transaction-id="@transaction.Id"
                       data-description="@transaction.Description"
                       data-transaction-date="@transaction.TransactionDate.ToString("dd MMM yyyy")"
                       data-account-id="@transaction.AccountId"
                       data-account-number="@transaction.AccountNumber"
                       data-amount="@transaction.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                       class="person-item list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 px-3 rounded-lg mb-2 shadow-sm"
                       style="cursor:pointer;">
                        <div class="d-flex flex-column">
                            <h6 class="mb-0 fw-bold">@transaction.Description</h6>
                            <small class="text-muted">@transaction.AccountNumber</small>
                        </div>
                        <div class="text-end">
                            @if (isDebit)
                            {
                                <div class="text-danger fw-semibold">- R @Math.Abs(transaction.Amount).ToString("N2")</div>
                            }
                            else
                            {
                                <div class="text-success fw-semibold">R @transaction.Amount.ToString("N2")</div>
                            }
                        </div>
                    </a>
                }
            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-lg-8">
            @if (transactions.Any())
            {
                <div class="details-panel p-4" style="max-height: calc(100vh - 180px); overflow-y: auto;">

                    <!-- Top -->
                    <div class="d-flex flex-column flex-md-row align-items-center justify-content-between mb-5">

                        <div class="d-flex align-items-center gap-4">
                            <div>
                                <h2 id="tx-description" class="fw-bold mb-1">@((first != null && !string.IsNullOrWhiteSpace(first.Description)) ? first.Description : "No transaction selected")</h2>
                                <p id="tx-meta" class="text-muted mb-2">@((first != null) ? first.TransactionDate.ToString("dd MMM yyyy") + " • " + first.AccountNumber : "-")</p>

                                <span id="tx-badge" class="badge bg-success badge-status">@((first != null) ? "Completed" : "")</span>
                            </div>
                        </div>

                        <div class="mt-4 mt-md-0">
                            <div class="dropdown ms-auto">
                                <button class="btn btn-sm p-1 border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="More options">
                                    <span class="kebab text-dark fs-3" aria-hidden="true">&#x22EE;</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <button type="button" class="dropdown-item" onclick="(function(){ var el = document.querySelector('.person-item.active'); if(!el) return false; var tx = { Id: el.getAttribute('data-transaction-id'), AccountId: el.getAttribute('data-account-id'), Amount: el.getAttribute('data-amount'), TransactionDate: el.getAttribute('data-transaction-date'), Description: el.getAttribute('data-description') }; if (typeof openEditTransactionModal === 'function') openEditTransactionModal(tx); return false; })();">
                                            <i class="bi bi-pencil me-2" aria-hidden="true"></i>Edit
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Transaction Details (Bootstrap rows) -->
                    <div class="mb-4">
                        @{ /* reuse 'first' declared earlier */ var isDebitFirst = (first != null && first.Amount < 0); }
                        <div class="row py-1 align-items-center">
                            <div class="col-auto col-sm-3 text-muted">Reference</div>
                            <div id="tx-id" class="col fw-semibold">@first.Id.ToString()</div>
                        </div>

                        <div class="row py-1 align-items-center">
                            <div class="col-auto col-sm-3 text-muted">Date</div>
                        <div id="tx-date" class="col fw-semibold">@first.TransactionDate.ToString("dd MMM yyyy")</div>
                        </div>

                        <div class="row py-1 align-items-center">
                            <div class="col-auto col-sm-3 text-muted">Account</div>
                            <div id="tx-account" class="col fw-semibold">@first.AccountNumber</div>
                        </div>

                        <div class="row py-1 align-items-center">
                            <div class="col-auto col-sm-3 text-muted">Amount</div>
                            <div id="tx-amount" class="col fw-semibold @(isDebitFirst ? "text-danger" : "text-success")">@((first != null) ? (isDebitFirst ? ("- R " + Math.Abs(first.Amount).ToString("N2")) : ("R " + first.Amount.ToString("N2"))) : "-")</div>
                        </div>

                        <div class="row py-1 align-items-center">
                            <div class="col-auto col-sm-3 text-muted">Status</div>
                            <div id="tx-status-text" class="col fw-semibold">Completed</div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="details-panel p-4 d-flex align-items-center justify-content-center" style="max-height: calc(100vh - 180px);">
                    <div id="no-selection" class="text-center py-5">
                        <div class="rounded-3 d-flex align-items-center justify-content-center text-muted mx-auto" style="width:120px;height:120px;">
                            <img src="@Url.Content("~/assets/img/files-svgrepo-com.svg")" alt="No transactions" style="width:72px;height:72px;" />
                        </div>
                        <p class="text-muted mt-3">No transactions</p>
                    </div>
                </div>
            }
        </div>
        @await Html.PartialAsync("partials/_UpdateTransactionModel")

    </div>
</div>
@section Scripts {
    <script src="@Url.Content("~/js/transaction.js")"></script>
    <script src="@Url.Content("~/js/transactions.js")"></script>
}
