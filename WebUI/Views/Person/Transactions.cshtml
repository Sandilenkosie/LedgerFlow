@model IEnumerable<Application.ViewModels.TransactionViewModel>

@{
    ViewData["Title"] = "Transactions";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class=" py-0">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-0">Transactions Management</h2>
            <p class="text-muted mb-0">Manage transactions and related accounts</p>
        </div>
    </div>

<script>
    (function(){
        // Helper to format currency
        function formatCurrency(value){
            var num = Number(value);
            if (isNaN(num)) return value;
            return 'R ' + num.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function clearActive(){
            document.querySelectorAll('.person-item.active').forEach(function(el){
                el.classList.remove('active');
            });
        }

        function setDetailsFromElement(el){
            var desc = el.getAttribute('data-description') || '';
            var date = el.getAttribute('data-transaction-date') || '';
            var acc = el.getAttribute('data-account-number') || '';
            var amount = el.getAttribute('data-amount');
            var id = el.getAttribute('data-transaction-id') || '';

            document.getElementById('tx-description').textContent = desc || 'No transaction selected';
            document.getElementById('tx-meta').textContent = (date ? date + ' • ' + acc : '-');
            document.getElementById('tx-badge').textContent = desc ? 'Completed' : '';

            document.getElementById('tx-id').textContent = id || '-';
            document.getElementById('tx-date').textContent = date || '-';
            document.getElementById('tx-account').textContent = acc || '-';
            document.getElementById('tx-amount').textContent = amount ? formatCurrency(amount) : '-';
            document.getElementById('tx-status-text').textContent = desc ? 'Completed' : '-';
        }

        document.addEventListener('DOMContentLoaded', function(){
            var items = document.querySelectorAll('.person-item');
            if (!items || items.length === 0) return;

            // Set first as active by default
            var first = items[0];
            if(first){
                first.classList.add('active');
                setDetailsFromElement(first);
            }

            items.forEach(function(item){
                item.addEventListener('click', function(e){
                    e.preventDefault();
                    clearActive();
                    item.classList.add('active');
                    setDetailsFromElement(item);
                });
            });
        });
    })();
</script>
<!-- Active transaction styles moved to wwwroot/css/site.css -->
    <div class="row g-4">

        <!-- LEFT SIDE -->
        <div class="col-lg-4">

            <div class="card shadow-sm sidebar-card p-3" style="max-height: calc(100vh - 180px); overflow-y: auto;">

                <!-- Search -->
                <div class="mb-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </span>
                        <input type="text" class="form-control border-start-0" placeholder="Search transactions...">
                    </div>
                </div>

                <!-- Transactions list -->
                @foreach(var transaction in Model)
                {
                    var isDebit = transaction.Amount < 0;
                    <a href='#' data-transaction-id="@transaction.Id"
                       data-description="@transaction.Description"
                       data-transaction-date="@transaction.TransactionDate.ToString("dd MMM yyyy")"
                       data-account-number="@transaction.AccountNumber"
                       data-amount="@transaction.Amount"
                       class="person-item list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 px-3 rounded-lg mb-2 shadow-sm"
                       style="cursor:pointer;">
                        <div class="d-flex flex-column">
                            <h6 class="mb-0 fw-bold">@transaction.Description</h6>
                            <small class="text-muted">@transaction.AccountNumber</small>
                        </div>
                        <div class="text-end">
                            @if (isDebit)
                            {
                                <div class="text-danger fw-semibold">- R @Math.Abs(transaction.Amount).ToString("N2")</div>
                            }
                            else
                            {
                                <div class="text-success fw-semibold">R @transaction.Amount.ToString("N2")</div>
                            }
                        </div>
                    </a>
                }
            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-lg-8">

            <div class="details-panel p-4" style="max-height: calc(100vh - 180px); overflow-y: auto;">

                <!-- Top -->
                <div class="d-flex flex-column flex-md-row align-items-center justify-content-between mb-5">

                    <div class="d-flex align-items-center gap-4">
                        <div>
                            @{ var first = Model.FirstOrDefault(); }
                            <h2 id="tx-description" class="fw-bold mb-1">@((first != null && !string.IsNullOrWhiteSpace(first.Description)) ? first.Description : "No transaction selected")</h2>
                            <p id="tx-meta" class="text-muted mb-2">@((first != null) ? first.TransactionDate.ToString("dd MMM yyyy") + " • " + first.AccountNumber : "-")</p>

                            <span id="tx-badge" class="badge bg-secondary badge-status">
                                @((first != null) ? "Completed" : "")
                            </span>
                        </div>
                    </div>

                    <div class="mt-4 mt-md-0">
                        <div class="dropdown ms-auto">
                            <button class="btn btn-sm p-1 border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="More options">
                                <span class="kebab text-dark fs-3" aria-hidden="true">&#x22EE;</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href=@Url.Action("MakeTransaction", "Person", new { Id = "ACC-2026-001" }) ><i class="fa-solid fa-pen me-2"></i>Make Transaction</a></li>
                                <li><a class="dropdown-item" href="#"><i class="fa-solid fa-pen me-2"></i>Edit</a></li>
                                <li><button class="dropdown-item text-danger" type="button"><i class="fa-solid fa-trash me-2"></i>Remove</button></li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Transaction Details (Bootstrap rows) -->
                <div class="mb-4">
                    @{ var tx = Model.FirstOrDefault(); }
                    <div class="row py-1 align-items-center">
                        <div class="col-auto col-sm-3 text-muted">Reference</div>
                        <div id="tx-id" class="col fw-semibold">@((tx != null) ? tx.Id.ToString() : "-")</div>
                    </div>

                    <div class="row py-1 align-items-center">
                        <div class="col-auto col-sm-3 text-muted">Date</div>
                        <div id="tx-date" class="col fw-semibold">@((tx != null) ? tx.TransactionDate.ToString("dd MMM yyyy") : "-")</div>
                    </div>

                    <div class="row py-1 align-items-center">
                        <div class="col-auto col-sm-3 text-muted">Account</div>
                        <div id="tx-account" class="col fw-semibold">@((tx != null) ? tx.AccountNumber : "-")</div>
                    </div>

                    <div class="row py-1 align-items-center">
                        <div class="col-auto col-sm-3 text-muted">Amount</div>
                        <div id="tx-amount" class="col fw-semibold text-danger">@((tx != null) ? ("R " + tx.Amount.ToString("N2")) : "-")</div>
                    </div>

                    <div class="row py-1 align-items-center">
                        <div class="col-auto col-sm-3 text-muted">Status</div>
                        <div id="tx-status-text" class="col fw-semibold">@((tx != null) ? "Completed" : "-")</div>
                    </div>
                </div>

                <!-- Related: Account Summary & Recent Transactions -->
                <div class="related-section mt-4">
                    <div class="row">
                        <div class="col-12">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h5 class="mb-0">Account</h5>
                                <a href='@Url.Action("Details", "Account", new { id = "ACC-2026-001" })' class="small">View account</a>
                            </div>

                            <div class="mb-3">
                                <div class="fw-semibold">@((tx != null) ? tx.AccountNumber : "-")</div>
                                <small class="text-muted">@((tx != null) ? ("• Available R " + tx.Amount.ToString("N2")) : "-")</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
