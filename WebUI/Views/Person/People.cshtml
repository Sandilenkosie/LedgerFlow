@using Application.ViewModels
@model IEnumerable<Application.ViewModels.PersonViewModel>

@{
    ViewData["Title"] = "All People";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class=" py-0">
    @Html.AntiForgeryToken()

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-0">People Management</h2>
            <p class="text-muted mb-0">Manage persons, accounts and transactions</p>
        </div>

        <button type="button" id="open-add-person" class="btn btn-primary px-4 py-2 rounded-pill" data-bs-toggle="modal" data-bs-target="#addPersonModal">
            <i class="bi bi-plus me-2" aria-hidden="true"></i>
            Add Person
        </button>

    </div>
        <!-- Horizontal actions (Close / Re-open) -->
    <style>
        .account-action { color: #8B0000; text-decoration: none; }
        .account-action.disabled-action { color: var(--bs-gray-500, #6c757d); pointer-events: none; opacity: 0.8; }
    </style>

    <div class="d-flex gap-3 align-items-center mt-3">
        <a href="#" id="add-account-action" class="account-action disabled-action d-inline-flex align-items-center"
           aria-disabled="true" tabindex="-1">
            <i class="bi bi-unlock-fill me-2" aria-hidden="true"></i>
            <span class="fw-semibold">Add account</span>
        </a>
     </div> 
    <div class="row g-4">

        <!-- LEFT SIDE -->
        <div class="col-lg-4">

            <div class="card shadow-sm sidebar-card p-3 d-flex flex-column" style="max-height: calc(100vh - 180px);">

                <div class="flex-grow-1 overflow-auto">
                    <!-- Search -->
                    <div class="mb-4">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="bi bi-search" aria-hidden="true"></i>
                            </span>
                            <input type="text" class="form-control border-start-0" placeholder="Search people...">
                        </div>
                    </div>

                    <!-- Person -->
                <div class="list-group">
                    @foreach (var person in Model)
                    {
                        <a href="#"
                        role="button"
                        data-id="@person.Id"
                        data-name="@person.Name"
                        data-idnumber="@person.IdNumber"
                        data-username="@person.Username"
                        data-accounts='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(person.Accounts.Select(a => new { Id = a.Id, AccountNumber = a.AccountNumber, IsClosed = a.IsClosed, AccountType = a.AccountType, Created = a.Created, OwnerName = person.Name })))'
                        data-transactions='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(person.Accounts.SelectMany(a => a.Transactions).Select(t => new { Id = t.Id, Amount = t.Amount, Description = t.Description, AccountId = t.AccountId })))'
                        class="person-item list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 px-3 rounded-lg mb-2 shadow-sm"
                        style="cursor:pointer;">

                            <div>
                                <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center fw-bold"
                                style="width:48px;height:48px;">@(person.Name != null && person.Name.Length > 0 ? person.Name.Substring(0,1).ToUpper() : "")</div>
                            </div>

                            <div class="flex-grow-1" style="min-width:0;">
                                <div class="d-flex flex-column">
                                    <div class="fw-semibold text-truncate">@person.Name</div>
                                    <small class="text-muted text-truncate">@person.Username</small>
                                </div>
                            </div>

                            <div class="ms-2 text-muted d-none d-sm-flex align-items-center">
                                <i class="bi bi-chevron-right"></i>
                            </div>

                        </a>
                    }
                </div>
                </div>

                <!-- Footer pinned to bottom of card -->
                <div class="mt-3 pt-3 border-top">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">Showing @Model.Count() items</small>

                        <div class="btn-group btn-group-sm" role="group" aria-label="People paging">
                            @if (ViewBag.Page > 1)
                            {
                                <a class="btn btn-outline-secondary rounded-pill d-flex align-items-center" href="@Url.Action("People", "Person", new { page = (ViewBag.Page - 1), size = ViewBag.PageSize })" aria-label="Previous page">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary rounded-pill disabled d-flex align-items-center" aria-disabled="true" aria-label="Previous page">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                            }

                            <span class="btn btn-primary rounded-circle mx-1 d-inline-flex align-items-center justify-content-center" role="status" aria-current="page" style="width:28px;height:28px;padding:0;font-size:0.85rem;line-height:1;">@ViewBag.Page</span>

                            @if (Model.Count() >= ViewBag.PageSize)
                            {
                                <a class="btn btn-outline-secondary rounded-pill d-flex align-items-center" href="@Url.Action("People", "Person", new { page = (ViewBag.Page + 1), size = ViewBag.PageSize })" aria-label="Next page">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary rounded-pill disabled d-flex align-items-center" aria-disabled="true" aria-label="Next page">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-lg-8">

            <div class="details-panel p-4" style="max-height: calc(100vh - 180px); overflow-y: auto;">

                <!-- Placeholder when no person is selected -->
                <div id="no-selection" class="text-center py-5">
                    <div class="rounded-3 d-flex align-items-center justify-content-center text-muted mx-auto" style="width:120px;height:120px;">
                        <img src="@Url.Content("~/assets/img/files-svgrepo-com.svg")" alt="User" style="width:72px;height:72px;" />
                    </div>
                    <p class="text-muted mt-3">No selected person</p>
                </div>

                <!-- Person details (hidden until a person is selected) -->
                <div id="person-details" class="d-none">
                    <!-- Top -->
                    <div class="d-flex flex-column flex-md-row align-items-center justify-content-between mb-5">

                        <div class="d-flex align-items-center gap-4">
                            <div class="rounded-3 bg-light d-flex align-items-center justify-content-center text-muted" style="width:80px;height:80px;">
                                <img src="@Url.Content("~/assets/img/files-svgrepo-com.svg")" alt="User" style="width:40px;height:40px;" />
                            </div>

                            <div>
                                <h2 id="person-name" class="fw-bold mb-1"></h2>
                                <p id="person-username-text" class="text-muted mb-2"></p>

                                <span id="badge-status" class="badge bg-success badge-status">
                                    Active Account
                                </span>
                            </div>
                        </div>

                        <div class="mt-4 mt-md-0">
                            <div class="dropdown ms-auto">
                                <button class="btn btn-sm p-1 border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="More options">
                                    <span class="kebab text-dark fs-3" aria-hidden="true">&#x22EE;</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item"
                                        href="#"
                                        onclick='openUpdatePersonModalFromCurrent()'>
                                            <i class="bi bi-pencil me-2" aria-hidden="true"></i>Edit
                                        </a>
                                    </li>
                                    <li>
                                        <a href="#" id="delete-person-action" class="dropdown-item text-danger disabled-action d-inline-flex align-items-center" aria-disabled="true" tabindex="-1" onclick="deleteCurrentPerson(); return false;">
                                            <i class="bi bi-trash me-2" aria-hidden="true"></i>
                                            <span class="fw-semibold">Remove</span>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    @await Html.PartialAsync("partials/_UpdatePersonModal")

                    <!-- Person Details (Bootstrap rows) -->
                    <div class="mb-4">
                        <div class="row py-1 align-items-center">
                            <div class="col-auto col-sm-3 text-muted">Full Name</div>
                            <div id="detail-fullname" class="col fw-semibold">&nbsp;</div>
                        </div>

                        <div class="row py-1 align-items-center">
                            <div class="col-auto col-sm-3 text-muted">ID Number</div>
                            <div id="detail-idnumber" class="col fw-semibold" aria-live="polite"></div>
                        </div>
                    </div>

                    <!-- Related: Accounts & Transactions (list view) -->
                    <div class="related-section mt-4">
                        <div class="row">
                            <div class="col-12">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <h5 class="mb-0">Accounts</h5>
                                    <a href='@Url.Action("Accounts","Person")' class="small">View all</a>
                                </div>

                                <ul id="accounts-list" class="list-group mb-3">
                                </ul>

                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <h5 class="mb-0">Recent Transactions</h5>
                                    <a href='@Url.Action("Transactions","Person")' class="small">View all</a>
                                </div>

                                <ul id="transactions-list" class="list-group">
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>
@await Html.PartialAsync("Partials/_AddPersonModal")
@await Html.PartialAsync("Partials/_AddAccountModel")

<!-- Confirmation modal for deleting a person -->
<form id="confirmDeletePersonForm" asp-controller="Person" asp-action="DeletePerson" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="confirm-delete-person-id" />
    <div class="modal fade" id="confirmDeletePersonModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm action</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="confirmDeletePersonModalBody">Are you sure you want to remove this person?</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDeletePersonConfirm">Yes, remove</button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script src="@Url.Content("~/js/RelatedAccount.js")"></script>
    <script src="@Url.Content("~/js/RelatedTransaction.js")"></script>
    <script src="@Url.Content("~/js/person.js")"></script>
    <script src="@Url.Content("~/js/action_people.js")"></script>
}
