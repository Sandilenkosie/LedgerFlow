@{
    ViewData["Title"] = "Home Page";
    string fullName = "Sandile Nkosi";
    var names = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    string initials = $"{names.First()[0]}{names.Last()[0]}".ToUpper();
    ViewData["Initials"] = initials;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ledger Flow | @ViewData["Title"]</title>
    <link rel="apple-touch-icon" sizes="180x180" href="@Url.Content("~/assets/img/favicon_io/apple-touch-icon.png")">
    <link rel="icon" type="image/png" sizes="32x32" href="@Url.Content("~/assets/img/favicon_io/favicon-32x32.png")">
    <link rel="icon" type="image/png" sizes="16x16" href="@Url.Content("~/assets/img/favicon_io/favicon-16x16.png")">
    <link rel="manifest" href="@Url.Content("~/assets/img/favicon_io/site.webmanifest")">
    <meta name="theme-color" content="#ffffff">
    <!-- Google Fonts + Bootstrap + Icons + Chart.js -->
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="@Url.Content("~/css/site.css")" rel="stylesheet">
</head>
<body>
    <div class="d-flex">
        @await Html.PartialAsync("Partials/Sidebar")

        <div class="flex-grow-1">
            @await Html.PartialAsync("Partials/Topnav")

            <main class="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <div class="mobile-overlay" id="mobileOverlay"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/assets/js/toastr-init.js"></script>
    <script>
        // Ensure modal cancel/close resets any forms inside the modal and clears validation messages
        $(function(){
            $(document).on('hidden.bs.modal', '.modal', function () {
                try {
                    var $modal = $(this);
                    // reset native form fields
                    $modal.find('form').each(function(){
                        try { this.reset(); } catch (e) {}
                        // clear client-side validation messages (commonly .text-danger)
                        $(this).find('.text-danger').text('');
                        // re-enable any disabled buttons inside modal
                        $(this).find('button, input, select, textarea').prop('disabled', false);
                    });
                } catch (e) {
                    // swallow errors to avoid breaking global scripts
                    console && console.warn && console.warn('modal reset failed', e);
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


