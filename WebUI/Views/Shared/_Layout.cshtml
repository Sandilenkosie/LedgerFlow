<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <script type="importmap"></script>
        <title>Ledger Flow | @ViewData["Title"]</title>
        <link rel="apple-touch-icon" sizes="180x180" href="@Url.Content("~/assets/img/favicon_io/apple-touch-icon.png")">
        <link rel="icon" type="image/png" sizes="32x32" href="@Url.Content("~/assets/img/favicon_io/favicon-32x32.png")">
        <link rel="icon" type="image/png" sizes="16x16" href="@Url.Content("~/assets/img/favicon_io/favicon-16x16.png")">
        <link rel="manifest" href="@Url.Content("~/assets/img/favicon_io/site.webmanifest")">
        <meta name="theme-color" content="#ffffff">


        <!-- ===============================================-->
        <!--    Stylesheets-->
        <!-- ===============================================-->
        <link rel="preconnect" href="https://fonts.gstatic.com">
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700&amp;display=swap" rel="stylesheet">
    <link href="@Url.Content("~/assets/css/theme.css")" rel="stylesheet" />
    @* Toastr styles for server-side notifications *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    @* <link href="@Url.Content("~/css/site.css")" rel="stylesheet" /> *@
    </head>
    <body>
        <header>
            @await Html.PartialAsync("Partials/Nav")
        </header>
            <div class="bg-dark">
                <img class="img-fluid position-absolute end-0" src="@Url.Content("~/assets/img/hero/hero-bg.png")" alt="" />
            </div>
            <main class="main" id="top">

                @RenderBody()
            </main>
            @* Server-side notifications will be shown via Toastr *@
        <footer class="border-top footer text-muted">
            @await Html.PartialAsync("Partials/Footer")
            &copy; 2026 - Ledger - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </footer>
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <!-- ===============================================-->
        <!--    JavaScripts-->
        <!-- ===============================================-->
        <script src="vendors/bootstrap/bootstrap.min.js"></script>
        <script src="vendors/is/is.min.js"></script>
        <script src="vendors/fontawesome/all.min.js"></script>
        <script src="vendors/lodash/lodash.min.js"></script>
        <script src="https://polyfill.io/v3/polyfill.min.js?features=window.scroll"></script>
        <script src="assets/js/theme.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
        <script>
            // expose server toast data to client script
            window.__serverToastr = {
                msg: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewData["ToastMessage"] ?? null)),
                type: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewData["ToastType"] ?? "info"))
            };
        </script>
        <script src="/assets/js/toastr-init.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>
