<!-- Update Person Modal -->
<div class="modal fade" id="updatePersonModal" tabindex="-1" aria-labelledby="updatePersonModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="update-person-form" asp-action="UpdatePerson" asp-controller="Person" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="updatePersonModalLabel">Update Person</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" name="Id" id="person-id" />


                    <div class="mb-3">
                        <label for="person-fullname" class="form-label">Full Name</label>
                        <input type="text" class="form-control" id="person-fullname" name="Name" required />
                    </div>

                    <div class="mb-3">
                        <label for="person-username-input" class="form-label">Username</label>
                        <input type="text" class="form-control" id="person-username-input" name="Username" required />
                    </div>

                    <div class="mb-3">
                        <label for="person-idnumber" class="form-label">ID Number</label>
                        <input type="text" class="form-control" id="person-idnumber" name="IdNumber" />
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Helper script: call openUpdatePersonModal(person) with an object to populate and show modal *@
<script>
    function openUpdatePersonModal(person) {
        // person: { id, name, username, idNumber }
        function setValueIfExists(id, value) {
            var el = document.getElementById(id);
            if (!el) {
                console.warn('Element not found for id:', id);
                return;
            }
            try {
                el.value = value ?? '';
            } catch (e) {
                // some elements might not support .value
                el.textContent = value ?? '';
            }
        }

        setValueIfExists('person-id', person?.id ?? person?.Id ?? '');
        setValueIfExists('person-fullname', person?.name ?? person?.Name ?? person?.fullName ?? person?.FullName ?? '');
        setValueIfExists('person-username-input', person?.username ?? person?.Username ?? '');
        setValueIfExists('person-idnumber', person?.idNumber ?? person?.IdNumber ?? '');

        var modalEl = document.getElementById('updatePersonModal');
        if (!modalEl) {
            console.warn('updatePersonModal element not found');
            return;
        }

        if (typeof showModalElement === 'function') {
            showModalElement(modalEl);
        } else {
            var modal = new bootstrap.Modal(modalEl);
            modal.show();
        }
    }
</script>
