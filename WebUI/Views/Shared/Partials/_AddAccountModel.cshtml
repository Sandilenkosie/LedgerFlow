<!-- Add Account Modal -->
<div class="modal fade" id="addAccountModal" tabindex="-1" aria-labelledby="addAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="add-account-form" asp-action="AddAccount" asp-controller="Person" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="addAccountModalLabel">Add Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    @* Default the hidden user id to the current user's NameIdentifier claim when available. *@
                    <input type="hidden" name="userId" id="person-id" />

                    <div class="mb-3">
                        <label for="account-type" class="form-label">Account Type</label>
                        <select id="account-type" name="AccountType" class="form-select">
                            <option value="Primary">Primary</option>
                            <option value="Savings">Savings</option>
                            <option value="Investment">Investment</option>
                            <option value="Current">Current</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="initial-balance" class="form-label">Initial Balance</label>
                        <input id="initial-balance" name="Balance" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Account</button>
                </div>
            </form>
        </div>
    </div>
</div>
