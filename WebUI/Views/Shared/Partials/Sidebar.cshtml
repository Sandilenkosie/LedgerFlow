<!-- Sidebar -->
<aside class="sidebar" aria-label="Sidebar">
    <div class="sidebar-header">
        <img src="@Url.Content("~/assets/img/logo-icon.svg")" alt="" width="50" />
        <div>
            <div class="title">Ledger</div>
            <div class="subtitle">Admin Console</div>
        </div>
    </div>

    <div class="sidebar-nav">
        <nav class="nav flex-column">
            <a class="nav-link active" href="@Url.Action("dashboard", "person")"><i class="bi bi-house-fill"></i> Dashboard</a>
            <a class="nav-link" href="@Url.Action("all", "person")"><i class="bi bi-people-fill"></i> People</a>
            <a class="nav-link" href="@Url.Action("accounts", "person")"><i class="bi bi-people-fill"></i> Accounts</a>
            <a class="nav-link" href="@Url.Action("transactions", "person")"><i class="bi bi-people-fill"></i> Transactions</a>
            <a class="nav-link" href="#"><i class="bi bi-calendar-check-fill"></i> Reports</a>
            <a class="nav-link" href="#"><i class="bi bi-gear-fill"></i> Settings</a>
        </nav>
    </div>

    <div class="sidebar-footer">
        <div class="avatar">AM</div>
        <div>
            <div class="fw-semibold">Admin Manager</div>
            <div class="small text-muted">Security admin</div>
        </div>
        <div class="ms-auto">
            <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-box-arrow-right"></i></button>
            </form>
        </div>
    </div>
</aside>